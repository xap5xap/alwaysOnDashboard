{
  "name": "@vela/app",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "device:build": "ANDROID_HOME=$HOME/Library/Android/sdk JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home npx eas build --local -p android --profile preview --output $HOME/Downloads/vela-preview.apk",
    "device:install": "$HOME/Library/Android/sdk/platform-tools/adb install -r $HOME/Downloads/vela-preview.apk",
    "device:build:prod": "ANDROID_HOME=$HOME/Library/Android/sdk JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home npx eas build --local -p android --profile preview-prod --output $HOME/Downloads/vela-prod.apk",
    "device:install:prod": "$HOME/Library/Android/sdk/platform-tools/adb install -r $HOME/Downloads/vela-prod.apk"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/query-sync-storage-persister": "^5.101.1",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-persist-client": "^5.101.1",
    "@vela/shared": "*",
    "expo": "~56.0.12",
    "expo-brightness": "~56.0.5",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-keep-awake": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-screen-orientation": "~56.0.5",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "0.35.10",
    "react-native-purchases": "^10.4.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-unistyles": "3.2.5",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "56.0.5",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  }
}
