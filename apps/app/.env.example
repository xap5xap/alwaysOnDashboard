# Vela app environment (Expo inlines EXPO_PUBLIC_* at build time).
# For local development point these at the local Supabase stack. After `npm run db:start`
# (supabase start) at the repo root, read the values from `supabase status`:
#   API URL   -> EXPO_PUBLIC_SUPABASE_URL
#   anon key  -> EXPO_PUBLIC_SUPABASE_ANON_KEY
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
